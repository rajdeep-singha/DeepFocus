    "add-external": "npx tsx cli/add-external.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "marked": "^14.1.3",
    "node-fetch": "^3.3.2",
    "slugify": "^1.6.6",
    "youtube-transcript": "^1.2.1"
  }
