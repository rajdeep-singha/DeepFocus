{
  "name": "metadata-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:content && cd web && npx vite",
    "build": "npm run build:content && cd web && npx vite build",
    "build:content": "npx tsx scripts/build-content.ts",
    "preview": "cd web && npx vite preview",
